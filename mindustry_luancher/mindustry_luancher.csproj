<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>

		<AssemblyName>MDL_Launcher</AssemblyName>
		<Version>0.0.9-beta</Version>
		<FileVersion>0.0.9-beta</FileVersion>

		<ApplicationIcon>icon.ico</ApplicationIcon>
		<Company>Color_Garden</Company>
		<Product>MDL启动器</Product>
		<Copyright>Copyright © 2026</Copyright>
	</PropertyGroup>
	<ItemGroup>
	  <None Remove="Assets\itch_logo.png" />
	  <None Remove="Assets\steam_logo.png" />
	  <None Remove="Fonts\font.ttf" />
	</ItemGroup>
	<ItemGroup>
	  <Resource Include="Assets\itch_logo.png" />
	  <Resource Include="Assets\steam_logo.png" />
	  <Resource Include="Fonts\font.ttf" />
	</ItemGroup>
</Project>